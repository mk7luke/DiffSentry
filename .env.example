# === GitHub App ===
GITHUB_APP_ID=your-app-id
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# === AI Provider (choose one) ===
AI_PROVIDER=anthropic  # "anthropic" or "openai"

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.example.com

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://your-openai-proxy.example.com

# === Server ===
PORT=3005
LOG_LEVEL=info

# === Review Settings ===
MAX_FILES_PER_REVIEW=50
# Comma-separated glob patterns to skip
IGNORED_PATTERNS=

# === Bot Identity ===
BOT_NAME=diffsentry  # used for @mention detection in chat commands

# === Learnings Storage ===
LEARNINGS_DIR=./data/learnings  # directory for per-repo learning files

# === SQLite Persistence ===
# Leave default for on-disk SQLite at ./data/diffsentry.db.
# Set DB_PATH="" to disable persistence (dashboard becomes empty).
# DB_PATH=./data/diffsentry.db

# === Web Dashboard (optional, off by default) ===
# ENABLE_DASHBOARD=1            # mount /dashboard on the webhook server
# DASHBOARD_URL=https://diffsentry.example.com/dashboard  # base URL for OAuth callbacks
# GITHUB_OAUTH_CLIENT_ID=        # from the GitHub App's OAuth settings
# GITHUB_OAUTH_CLIENT_SECRET=
# DASHBOARD_ALLOWED_ORGS=mk7luke # comma-separated: only members of these orgs may log in
# DASHBOARD_SESSION_SECRET=       # defaults to GITHUB_WEBHOOK_SECRET if unset
