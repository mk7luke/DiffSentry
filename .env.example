# === GitHub App ===
GITHUB_APP_ID=your-app-id
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# === AI Provider (choose one) ===
AI_PROVIDER=anthropic  # "anthropic", "openai", or "openai-compatible"

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.example.com

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://your-openai-proxy.example.com

# Local / self-hosted models via any OpenAI-compatible endpoint
# (Ollama, LM Studio, vLLM, llama.cpp server, LocalAI, ...).
# See README "Using local models" for copy-paste examples per server.
# AI_PROVIDER=openai-compatible
# LOCAL_AI_BASE_URL=http://localhost:11434/v1   # Ollama
# LOCAL_AI_MODEL=llama3.1:70b
# LOCAL_AI_API_KEY=                             # optional; most local servers ignore it
# LOCAL_AI_JSON_MODE=true                       # set to "false" if your backend rejects response_format=json_object

# === AI Cost Tracking ===
# Every provider call records token usage + a computed USD cost to the
# cost_events table, surfaced on the dashboard's Cost page. Costs come from a
# built-in per-model price table; override or extend it with a JSON object
# mapping a model id (or family prefix, e.g. "gpt-4o") to USD per 1,000,000
# tokens. Unknown models still record tokens (cost 0) until you add a price.
# AI_MODEL_PRICES={"gpt-4o":{"input":2.5,"output":10},"claude-sonnet-4":{"input":3,"output":15}}
#
# Budgets are monthly USD ceilings per scope ('global' or 'owner/repo'), set on
# the Cost page (admin) and stored in the DB — not env. Crossing one emits a
# live `budget.exceeded` alert and an audit-log entry.

# === Server ===
PORT=3005
LOG_LEVEL=info

# === Review Settings ===
MAX_FILES_PER_REVIEW=50
# Comma-separated glob patterns to skip
IGNORED_PATTERNS=

# === Bot Identity ===
BOT_NAME=diffsentry  # used for @mention detection in chat commands

# === Learnings Storage ===
# Directory for learning files: per-repo at {owner}/{repo}.json, plus a single
# __global__.json holding cross-repo (global) learnings applied to every repo.
LEARNINGS_DIR=./data/learnings

# === SQLite Persistence ===
# Leave default for on-disk SQLite at ./data/diffsentry.db.
# Set DB_PATH="" to disable persistence (dashboard becomes empty).
# DB_PATH=./data/diffsentry.db

# === Web Dashboard (optional, off by default) ===
# ENABLE_DASHBOARD=1            # mount the SPA (/), JSON API (/api/v1), and legacy dashboard (/dashboard)
# DASHBOARD_URL=https://diffsentry.example.com/dashboard  # base URL for OAuth callbacks
# GITHUB_OAUTH_CLIENT_ID=        # from the GitHub App's OAuth settings
# GITHUB_OAUTH_CLIENT_SECRET=
# At least one of the two allowlists must be set. Either one grants access.
# Everyone who can sign in is a "viewer" (read-only) by default.
# DASHBOARD_ALLOWED_LOGINS=mk7luke   # comma-separated GitHub user logins
# DASHBOARD_ALLOWED_ORGS=my-org      # comma-separated GitHub org slugs (membership must be public or the user must consent to read:org)
# DASHBOARD_SESSION_SECRET=       # defaults to GITHUB_WEBHOOK_SECRET if unset
#
# Roles (RBAC): viewer < author < admin. Precedence: roles table (set in the
# Audit screen) > admin env > author env > viewer. Authors can trigger reviews
# and triage; admins can also edit config, manage roles, and read the audit log.
# DASHBOARD_ADMIN_LOGINS=mk7luke     # comma-separated logins granted admin
# DASHBOARD_AUTHOR_LOGINS=alice,bob  # comma-separated logins granted author
#
# Impact report: reviewer-minutes saved per finding (the only heuristic on the
# Impact page; every other number is counted from the raw tables). Default 15.
# IMPACT_MINUTES_PER_FINDING=15
#
# Realtime: the dashboard subscribes to GET /api/v1/stream (SSE) for live review
# + action events. Heartbeat keeps idle proxies from dropping the connection.
# DASHBOARD_SSE_HEARTBEAT_MS=25000   # heartbeat interval in ms (min 1000, default 25000)

# === Notifications (optional) ===
# Channels + alert rules are configured in the dashboard's Notifications screen.
# Only the email channel and the digest schedule need env config. (Budget alerts
# reuse the cost feature's DB-configured budgets on the Cost page — no env var.)
#
# Email channel (SMTP). Email channels stay disabled until HOST + FROM are set.
# NOTIFY_SMTP_HOST=smtp.example.com
# NOTIFY_SMTP_PORT=587               # 465 = implicit TLS; 587/25 = STARTTLS when offered
# NOTIFY_SMTP_FROM=diffsentry@example.com
# NOTIFY_SMTP_USER=                  # omit for unauthenticated relays
# NOTIFY_SMTP_PASS=
# NOTIFY_SMTP_SECURE=false           # force implicit TLS (auto-on for port 465)
#
# Weekly digest schedule (UTC). A 'digest' alert rule delivers the rollup.
# NOTIFY_DIGEST_DAY=1                # 0=Sun..6=Sat (default Monday)
# NOTIFY_DIGEST_HOUR=9              # 0-23 (default 09:00 UTC)
# NOTIFY_DIGEST_DISABLED=1          # set to disable the scheduled digest
#
# SSRF guard: webhook/Slack/Discord channel URLs must be https and may not target
# (or resolve to) loopback/private/link-local hosts. Two independent opt-outs for
# self-hosted/internal use (both off by default):
# NOTIFY_ALLOW_INSECURE_WEBHOOKS=true   # permit plain http:// (scheme only)
# NOTIFY_ALLOW_PRIVATE_WEBHOOKS=true    # permit private/loopback/link-local targets
#
# Branding: name your instance and pick a brand accent color so self-hosters can
# make it theirs. These are DEFAULTS — an admin can override them live in
# Settings → Branding (stored in SQLite; precedence: admin override > these env
# vars > built-in DiffSentry / #5a8dff). Theme (dark/light) and density are
# per-user and chosen in the UI, not via env.
# DASHBOARD_INSTANCE_NAME=DiffSentry  # shown in the sidebar wordmark + browser tab
# DASHBOARD_ACCENT_COLOR=#5a8dff      # hex color (#rgb or #rrggbb); recolors the whole UI
#
# Triage feedback (optional, OFF by default): when enabled, reviews drop any
# finding whose fingerprint a human has dismissed or currently snoozed in the
# command center's findings triage. Leave unset to keep review output unchanged.
# DIFFSENTRY_SUPPRESS_DISMISSED=1    # suppress dismissed/snoozed fingerprints in new reviews
#
# Platform API (bearer tokens): admins mint tokens from the /tokens screen to call
# /api/v1 from scripts (Authorization: Bearer dsk_...). Scopes: read | review.
# Tokens are stored hashed in the api_tokens table (no env var needed); the spec
# is at /api/v1/openapi.json and human docs at /api/v1/docs (both public).
#
# Config editor: admins can edit .diffsentry.yaml from the dashboard and either
# commit directly to the default branch or open a PR. PR mode creates a branch
# named with this prefix (default "diffsentry/config").
# DASHBOARD_CONFIG_PR_BRANCH_PREFIX=diffsentry/config
